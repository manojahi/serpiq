{
  "name": "serpiq",
  "version": "0.1.0",
  "description": "AI-powered SEO audit for any codebase. Reads your code, pulls Google Search Console data, and generates actionable improvements with blog briefs and pSEO plans.",
  "keywords": [
    "seo",
    "audit",
    "ai",
    "claude",
    "gpt",
    "openrouter",
    "search-console",
    "cli",
    "pseo",
    "keyword-research",
    "serpiq"
  ],
  "license": "MIT",
  "author": "manojahi (https://github.com/manojahi)",
  "homepage": "https://github.com/manojahi/serpiq#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manojahi/serpiq.git"
  },
  "bugs": {
    "url": "https://github.com/manojahi/serpiq/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "serpiq": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "glob": "^10.3.10",
    "googleapis": "^140.0.0",
    "open": "^10.1.0",
    "openai": "^4.50.0",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
